{
  "id": null,
  "uid": "cartracker-logs",
  "title": "Logs",
  "tags": ["logs", "loki"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "All Service Logs",
      "type": "logs",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "cartracker-loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "cartracker-loki"
          },
          "expr": "{job=~\".+\"}",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 2,
      "title": "Error / Warning Logs",
      "type": "logs",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "loki",
        "uid": "cartracker-loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "cartracker-loki"
          },
          "expr": "{job=~\".+\", level=~\"ERROR|WARNING\"}",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 3,
      "title": "Log Volume by Level",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "loki",
        "uid": "cartracker-loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "cartracker-loki"
          },
          "expr": "sum by (level) (count_over_time({job=~\".+\"} [5m]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    }
  ]
}
