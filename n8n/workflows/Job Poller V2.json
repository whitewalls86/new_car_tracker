    {
      "parameters": {
        "jsCode": "// Get all incoming items\nconst items = $input.all();\n\n// Object to hold counts per job_id\nconst counts = {};\n\n// Loop through each item\nfor (const item of items) {\n  const jobId = item.json.job_id;\n  const error = item.json.error\n  if (!counts[jobId]) {\n    counts[jobId] = 0;\n  }\n\n  if (error != null) {\n    counts[jobId]++;\n  } \n}\n\n// Convert to desired output format\nconst result = Object.entries(counts).map(([job_id, error_count]) => ({\n  json: {\n    job_id,\n    error_count\n  }\n}));\n\nreturn result;"
      },
