    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH run_errors AS (\n  SELECT\n    SUM(error::int) FILTER (WHERE error is not NULL) AS error_count\n    ,SUM(artifact_count) as artifact_count\n  FROM scrape_jobs\n  WHERE run_id = '{{ $json.run_id }}'::uuid\n)\nUPDATE runs\nSET status = CASE\n      WHEN (SELECT error_count FROM run_errors) > 0\n           AND (SELECT error_count FROM run_errors) < (SELECT artifact_count FROM run_errors )\n      THEN 'partial'\n      WHEN (SELECT error_count FROM run_errors) = (SELECT artifact_count FROM run_errors ) THEN 'failed'\n      ELSE 'success'\n    END,\n    total_count = (SELECT artifact_count FROM run_errors ),\n    finished_at = now(),\n    error_count = (SELECT error_count FROM run_errors),\n    last_error = NULL\nWHERE run_id = '{{ $json.run_id }}'::uuid\n  AND status = 'running';",
        "options": {}
      },
