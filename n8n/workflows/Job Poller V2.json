    {
      "parameters": {
        "operation": "executeQuery",
        "query": "DELETE FROM blocked_cooldown bc\nUSING (\n    SELECT bc.listing_id\n    FROM blocked_cooldown bc\n    LEFT JOIN ops.ops_vehicle_staleness vs\n        ON bc.listing_id = vs.listing_id\n    LEFT JOIN analytics.int_latest_price_by_vin pr\n        ON bc.listing_id = pr.price_listing_id\n    WHERE\n        vs.listing_id IS NULL\n        OR (\n            pr.price_observed_at > bc.last_attempted_at\n            AND pr.price IS NOT NULL\n        )\n) stale\nWHERE bc.listing_id = stale.listing_id;",
        "options": {}
      },
