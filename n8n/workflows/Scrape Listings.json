        "operation": "executeQuery",
        "query": "UPDATE search_configs\nSET params = jsonb_set(\n  params,\n  '{sort_order}',\n  to_jsonb(\n    COALESCE(\n      params->'sort_rotation'->>(\n        (SELECT i FROM generate_series(0, jsonb_array_length(params->'sort_rotation') - 1) AS i\n         WHERE params->'sort_rotation'->>i = params->>'sort_order'\n         LIMIT 1\n        ) + 1\n      ),\n      params->'sort_rotation'->>0\n    )\n  )\n)\nWHERE enabled = true\n  AND params ? 'sort_rotation'\n  AND jsonb_array_length(params->'sort_rotation') > 0;",
