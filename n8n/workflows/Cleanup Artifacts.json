      "name": "Any Candidates?"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://cartracker-scraper:8000/cleanup/artifacts",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"artifacts\": {{ JSON.stringify($json.artifacts.map(r => ({ artifact_id: r.artifact_id, filepath: r.filepath }))) }}\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [832, -100],
