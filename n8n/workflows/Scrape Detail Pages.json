{
  "name": "Scrape Detail Pages",
  "nodes": [
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH candidates AS (\n  SELECT\n    ovs.vin,\n    ovs.current_listing_url,\n    ovs.listing_id,\n    ovs.tier1_seller_customer_id AS seller_customer_id,\n    ovs.listing_state,\n\n    ovs.is_price_stale,\n    ovs.is_full_details_stale,\n    ovs.stale_reason,\n\n    ovs.price_observed_at,\n    ovs.tier1_observed_at,\n\n    -- One-per-dealer (fallback to VIN if dealer id missing)\n    ROW_NUMBER() OVER (\n      PARTITION BY COALESCE(ovs.tier1_seller_customer_id::text, ovs.vin)\n      ORDER BY\n        -- prioritize full-details stale first, then price-only\n        CASE WHEN ovs.is_full_details_stale THEN 0 ELSE 1 END,\n        -- then oldest price first (nulls first)\n        COALESCE(ovs.price_observed_at, 'epoch'::timestamptz) ASC,\n        -- then oldest tier1 first\n        COALESCE(ovs.tier1_observed_at, 'epoch'::timestamptz) ASC\n    ) AS dealer_row_num\n\n  FROM ops.ops_vehicle_staleness ovs\n  WHERE\n    -- stale of either kind\n    (ovs.is_price_stale OR ovs.is_full_details_stale)\n    -- only fetch active vehicles\n    AND COALESCE(ovs.listing_state, 'active') = 'active'\n    -- must have a URL to fetch\n    AND ovs.current_listing_url IS NOT NULL\n)\nSELECT\n  vin,\n  current_listing_url,\n  seller_customer_id,\n  stale_reason,\n  is_price_stale,\n  is_full_details_stale,\n  price_observed_at,\n  tier1_observed_at,\n  listing_id\nFROM candidates\nWHERE dealer_row_num = 1\nORDER BY\n  CASE WHEN is_full_details_stale THEN 0 ELSE 1 END,\n  COALESCE(price_observed_at, 'epoch'::timestamptz) ASC\n--LIMIT 500\n  ;\n",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1120,
        320
      ],
      "id": "b8df12fe-b392-4e4e-b0f0-0987c1b884fd",
