    {
      "parameters": {
        "jsCode": "const run_id = $('Create Run Id').first().json.run_id;\nconst artifacts = $input.first().json.artifacts;\nconst listing_id = $input.first().json.meta.listing_id\n\nreturn artifacts.map(a => ({\n  json: {\n    ...a,\n    run_id,\n    listing_id\n  }\n}));\n"
