# ── Postgres superuser (used by Flyway migrations and ops/admin service) ──────
POSTGRES_PASSWORD=change_me_to_a_strong_password

# ── Scoped Postgres role passwords (Plan 65) ──────────────────────────────────
# Each service connects with a least-privilege role. Generate independently.
VIEWER_DB_PASSWORD=change_me
SCRAPER_DB_PASSWORD=change_me
DBT_DB_PASSWORD=change_me

# ── Google OAuth (Plan 65) ────────────────────────────────────────────────────
# Register at: console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://cartracker-scraper.duckdns.org/oauth2/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Cookie signing secret — must be exactly 16, 24, or 32 bytes (base64).
# Generate with: python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
OAUTH2_COOKIE_SECRET=change_me_32_byte_base64_string

# ── Authorization (Plan 82) ───────────────────────────────────────────────────
# DB-backed auth. Users are stored as SHA-256(AUTH_EMAIL_SALT || email) hashes.
# AUTH_EMAIL_SALT: random string kept secret; used when hashing emails in DB and at runtime.
# ADMIN_EMAIL: bootstraps the first admin row via Flyway (V009). Used once.
# TELEGRAM_CHAT_ID: optional; numeric chat ID for access-request notifications.
# Generate a salt: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_EMAIL_SALT=change_me_to_a_random_secret_string
ADMIN_EMAIL=your_email@gmail.com
TELEGRAM_CHAT_ID=

# ── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_me

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=cartracker
MINIO_ROOT_PASSWORD=change_me

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_USER_MANAGEMENT_JWT_SECRET=change_me
TELEGRAM_API=your-telegram-bot-token

# ── Internal API key (ops service) ───────────────────────────────────────────
FASTAPI_ADMIN_KEY=change_me
