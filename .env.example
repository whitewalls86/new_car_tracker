# ── Postgres superuser (used by Flyway migrations and ops/admin service) ──────
POSTGRES_PASSWORD=change_me_to_a_strong_password

# ── Scoped Postgres role passwords (Plan 65) ──────────────────────────────────
# Each service connects with a least-privilege role. Generate independently.
VIEWER_DB_PASSWORD=change_me
SCRAPER_DB_PASSWORD=change_me
DBT_DB_PASSWORD=change_me

# ── Google OAuth (Plan 65) ────────────────────────────────────────────────────
# Register at: console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://cartracker-scraper.duckdns.org/oauth2/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Cookie signing secret — must be exactly 16, 24, or 32 bytes (base64).
# Generate with: python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
OAUTH2_COOKIE_SECRET=change_me_32_byte_base64_string

# ── Authorization (Plan 82) ───────────────────────────────────────────────────
# DB-backed auth. Users are stored as SHA-256(AUTH_EMAIL_SALT || email) hashes.
# AUTH_EMAIL_SALT: random string kept secret; used when hashing emails in DB and at runtime.
# ADMIN_EMAIL: bootstraps the first admin row via Flyway (V009). Used once.
# TELEGRAM_CHAT_ID: optional; numeric chat ID for access-request notifications.
# Generate a salt: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_EMAIL_SALT=change_me_to_a_random_secret_string
ADMIN_EMAIL=your_email@gmail.com
TELEGRAM_CHAT_ID=

# ── Resend (email notifications) ─────────────────────────────────────────────
# Sign up at resend.com, verify cartracker.info domain, generate an API key.
RESEND_API_KEY=re_your_api_key_here

# ── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_me

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=cartracker
MINIO_ROOT_PASSWORD=change_me

# ── Lake snapshot downloads (Plan 120 Gate F) ─────────────────────────────────
# Bearer token required by GET /admin/snapshots/adaptive-refresh/* on ops.
# Unset/empty disables the routes entirely (503). CI/local callers pass it as
# scripts/download_lake_snapshot.py --token, or via $CARTRACKER_SNAPSHOT_TOKEN.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SNAPSHOT_DOWNLOAD_TOKEN=change_me_to_a_random_secret_string

# FlareSolverr image pin
# Keep this aligned with curl_cffi impersonation support in the scraper.
# Avoid :latest; browser upgrades can invalidate cached cf_clearance replay.
FLARESOLVERR_IMAGE=ghcr.io/flaresolverr/flaresolverr:v3.4.6
FLARESOLVERR_URL=http://flaresolverr:8191

# Optional TRAWL solver trial
# Start with: docker compose --profile trawl up -d redis-trawl trawl
# Then set FLARESOLVERR_URL=http://trawl:8191 and restart scraper.
TRAWL_IMAGE=ghcr.io/germondai/trawl:latest
TRAWL_BROWSER_POOL_SIZE=2
TRAWL_BROWSER_ACQUIRE_TIMEOUT_MS=30000
TRAWL_SESSION_TTL_SECONDS=3600
TRAWL_BROWSER_RECYCLE_AFTER_CONTEXTS=8
TRAWL_BROWSER_CONTENT_PROCESSES=2

# Detail scrape throttles
# Lower values are safer during Cars.com 403/Cloudflare pressure.
DETAIL_BATCH_SIZE=100
DETAIL_MAX_WORKERS=1
DETAIL_REQUEST_TIMEOUT_S=90
SCRAPER_DETAIL_MAX_WORKERS=1
SCRAPER_DETAIL_TIMEOUT_S=90

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_USER_MANAGEMENT_JWT_SECRET=change_me
TELEGRAM_API=your-telegram-bot-token

# ── Internal API key (ops service) ───────────────────────────────────────────
FASTAPI_ADMIN_KEY=change_me

# ── Lakekeeper REST catalog (Plan 112 Gate A1) ───────────────────────────────
# Standalone stack: docker-compose.lakehouse.yml -p cartracker-lakehouse.
# Isolated from production Postgres -- lakekeeper-postgres is its own
# container/volume. See docs/runbook_lakehouse.md.
LAKEKEEPER_IMAGE=quay.io/lakekeeper/catalog:v0.13.1
# Use a URL-safe/hex value, not arbitrary text -- this is substituted
# directly into lakekeeper-postgres's DSN URL, so symbols like @ : / # break
# DSN parsing (learned during VM A1 verification).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
LAKEKEEPER_DB_PASSWORD=change_me
# 16-byte (or longer) secret used by Lakekeeper to encrypt secrets at rest.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
LAKEKEEPER_PG_ENCRYPTION_KEY=change_me
# Catalog REST endpoint: container-DNS on the VM/local (http://lakekeeper:8181/catalog),
# or http://localhost:18181/catalog against the CI override's published port.
LAKEKEEPER_CATALOG_URI=http://lakekeeper:8181/catalog

# ── MLflow experiment provenance (Plan 112 Gate B) ───────────────────────────
# Standalone stack: docker-compose.mlflow.yml -p cartracker-mlflow.
# This first Gate B chunk is a provenance bridge only -- it uses an isolated
# SQLite backend store (no production Postgres, no Flyway migration) and an
# isolated MinIO artifact prefix (s3://${MINIO_BUCKET}/mlflow/artifacts/). No
# new secret is required: artifact access reuses MINIO_ROOT_USER/PASSWORD.
# See docs/runbook_lakehouse.md ("Gate B provenance smoke").
#
# Where scripts/log_lakehouse_experiment_provenance.py logs runs. Defaults to
# a local file store (file:./.cache/mlruns) when unset, so a bare host needs
# no server. Point at the standalone server for the browsable UI:
#   MLFLOW_TRACKING_URI=http://localhost:15000
MLFLOW_TRACKING_URI=file:./.cache/mlruns
# Environment tag recorded on each provenance run: local | vm | ci.
PROVENANCE_ENV=local
